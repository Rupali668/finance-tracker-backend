{
  "info": {
    "name": "Finance Tracker API",
    "_postman_id": "a34d0fd2-73b3-44d6-a65d-6fc4f933c0ba",
    "description": "Postman collection for the Finance Tracker Spring Boot backend with authentication.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Signup",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Aman Kumar\",\n  \"email\": \"aman@example.com\",\n  \"password\": \"1234\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/auth/signup", "host": ["{{baseUrl}}"], "path": ["api", "auth", "signup"] }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"aman@example.com\",\n  \"password\": \"1234\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
      }
    },
    {
      "name": "Get Profile",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "auth", "me"] }
      }
    },
    {
      "name": "Get All Transactions",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{baseUrl}}/api/transactions", "host": ["{{baseUrl}}"], "path": ["api", "transactions"] }
      }
    },
    {
      "name": "Get Summary",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{baseUrl}}/api/transactions/summary", "host": ["{{baseUrl}}"], "path": ["api", "transactions", "summary"] }
      }
    },
    {
      "name": "Create Transaction",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Metro Card Reload\",\n  \"amount\": 1500,\n  \"category\": \"Transport\",\n  \"type\": \"EXPENSE\",\n  \"date\": \"2026-04-22\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/transactions", "host": ["{{baseUrl}}"], "path": ["api", "transactions"] }
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8082" },
    { "key": "token", "value": "paste-login-token-here" }
  ]
}
